# ============================================
# StanexBot - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# cp .env.example .env    (Mac / Linux)
# copy .env.example .env  (Windows)
#
# For Vercel deployment: set these in Vercel Dashboard
# > Settings > Environment Variables
# ============================================

# Telegram Bot Token — from @BotFather after /newbot
TELEGRAM_BOT_TOKEN=1234567890:AAFbcdEfghIJklMnOPqrstUVwxyz-ABCdefg

# Telegram Group Chat ID — from getUpdates (must be negative)
GROUP_CHAT_ID=-1001234567890

# Google Sheets ID — from the sheet URL between /d/ and /edit
SHEET_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz1234567890

# Google Sheets Tab Name — exact name at the bottom of the sheet (case-sensitive)
SHEET_TAB=Plan of Action

# Google Service Account Credentials — base64-encoded JSON key
# Encode with:
#   Windows:  [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes((Get-Content -Raw "key.json")))
#   Mac/Linux: base64 -w 0 key.json
GOOGLE_CREDENTIALS_B64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwicHJvamVjdF9pZCI6InByZXBib3QtMTIzNDU2IiwicHJpdmF0ZV9rZXlfaWQiOiIuLi4ifQ==

# Trigger window — send alert when this many days or fewer remain (default: 7)
TRIGGER_DAYS=7
